{
  "name": "@hasna/identities",
  "version": "0.3.5",
  "description": "Open identity records for humans and AI agents",
  "type": "module",
  "main": "dist/src/index.js",
  "types": "src/index.ts",
  "bin": {
    "identities": "src/cli.ts",
    "identities-mcp": "src/mcp/index.ts",
    "identities-serve": "src/server/index.ts"
  },
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./src/index.ts",
      "import": "./dist/src/index.js"
    },
    "./sdk": {
      "bun": "./src/sdk/index.ts",
      "types": "./src/sdk/index.ts",
      "import": "./dist/src/sdk/index.js"
    },
    "./pg-store": {
      "bun": "./src/pg-store.ts",
      "types": "./src/pg-store.ts",
      "import": "./dist/src/pg-store.js"
    },
    "./migrations": {
      "bun": "./src/migrations.ts",
      "types": "./src/migrations.ts",
      "import": "./dist/src/migrations.js"
    },
    "./user-lifecycle": {
      "bun": "./src/user-lifecycle.ts",
      "types": "./src/user-lifecycle.ts",
      "import": "./dist/src/user-lifecycle.js"
    },
    "./pg-user-lifecycle": {
      "bun": "./src/pg-user-lifecycle.ts",
      "types": "./src/pg-user-lifecycle.ts",
      "import": "./dist/src/pg-user-lifecycle.js"
    },
    "./storage": {
      "bun": "./src/storage.ts",
      "types": "./src/storage.ts",
      "import": "./dist/src/storage.js"
    },
    "./browserplan": {
      "bun": "./src/browserplan.ts",
      "types": "./src/browserplan.ts",
      "import": "./dist/src/browserplan.js"
    },
    "./integrations": {
      "bun": "./src/integrations.ts",
      "types": "./src/integrations.ts",
      "import": "./dist/src/integrations.js"
    },
    "./instructions": {
      "bun": "./src/instructions.ts",
      "types": "./src/instructions.ts",
      "import": "./dist/src/instructions.js"
    },
    "./global-agent-rules": {
      "bun": "./src/global-agent-rules.ts",
      "types": "./src/global-agent-rules.ts",
      "import": "./dist/src/global-agent-rules.js"
    },
    "./ecosystem": {
      "bun": "./src/ecosystem.ts",
      "types": "./src/ecosystem.ts",
      "import": "./dist/src/ecosystem.js"
    },
    "./eve": {
      "bun": "./src/eve.ts",
      "types": "./src/eve.ts",
      "import": "./dist/src/eve.js"
    },
    "./status": {
      "bun": "./src/status.ts",
      "types": "./src/status.ts",
      "import": "./dist/src/status.js"
    },
    "./media": {
      "bun": "./src/media.ts",
      "types": "./src/media.ts",
      "import": "./dist/src/media.js"
    },
    "./roster": {
      "bun": "./src/roster.ts",
      "types": "./src/roster.ts",
      "import": "./dist/src/roster.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE",
    "SECURITY.md",
    "CODE_OF_CONDUCT.md",
    "PROMPT.md",
    "SOUL.md",
    "PERSONALITY.md",
    "ETHOS.md",
    "VOICE.md",
    "docs",
    "agents"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build": "bun run clean && bun build ./src/index.ts ./src/storage.ts ./src/http-store.ts ./src/pg-store.ts ./src/migrations.ts ./src/user-lifecycle.ts ./src/pg-user-lifecycle.ts ./src/version.ts ./src/browserplan.ts ./src/integrations.ts ./src/instructions.ts ./src/global-agent-rules.ts ./src/ecosystem.ts ./src/eve.ts ./src/status.ts ./src/media.ts ./src/roster.ts ./src/cli.ts ./src/mcp/index.ts ./src/server/index.ts ./src/sdk/index.ts --outdir dist --target bun --external pg --external @hasna/contracts --external @modelcontextprotocol/sdk --external zod && tsc --emitDeclarationOnly --outDir dist",
    "generate:sdk": "bun run scripts/generate-sdk.ts",
    "vendor-kit:check": "bunx @hasna/contracts vendor-kit . --check --no-contract",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "verify:release": "bun run typecheck && bun test && bun run vendor-kit:check && bun run build",
    "dev:cli": "bun run src/cli.ts",
    "dev:mcp": "bun run src/mcp/index.ts",
    "dev:serve": "bun run src/server/index.ts",
    "prepublishOnly": "bun run verify:release"
  },
  "keywords": [
    "identity",
    "identities",
    "ai",
    "agents",
    "humans",
    "mailery",
    "telephony",
    "mcp",
    "cli"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hasna/identities.git"
  },
  "homepage": "https://github.com/hasna/identities",
  "bugs": {
    "url": "https://github.com/hasna/identities/issues"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "author": "Andrei Hasna <andrei@hasna.com>",
  "license": "Apache-2.0",
  "devDependencies": {
    "typescript": "^5.7.3"
  },
  "dependencies": {
    "@hasna/contracts": "0.4.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/bun": "^1.2.4",
    "@types/node": "^22.13.4",
    "@types/pg": "^8.11.10",
    "jose": "6.2.3",
    "pg": "^8.16.3",
    "zod": "^3.24.2"
  }
}
